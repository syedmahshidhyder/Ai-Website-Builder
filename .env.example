# =====================================================
#  WebGenAI SaaS — Environment Variables
#  Copy this file to .env and fill in your keys
# =====================================================

# ── GROQ (FREE - Fastest AI, Recommended) ───────────
# Sign up free at: https://console.groq.com
# 14,400 requests/day free — no credit card
GROQ_API_KEY=

# ── GOOGLE GEMINI (FREE - Backup AI) ────────────────
# Get free key at: https://aistudio.google.com/app/apikey
# 1,500 requests/day free — just need Gmail
GEMINI_API_KEY=

# ── NETLIFY (FREE - For 1-click deploy feature) ──────
# Get token at: https://app.netlify.com/user/applications
# Click "New access token" — free account works
NETLIFY_TOKEN=

# ── SESSION SECRET ───────────────────────────────────
# Change this to any random words you like
SESSION_SECRET=webgenai-super-secret-change-this-2024

# ── PORT ─────────────────────────────────────────────
PORT=3000

# ── APP URL (set this when deployed online) ──────────
APP_URL=http://localhost:3000

# =====================================================
# NOTE: App works even with ZERO keys filled in!
# Pollinations.AI (no key needed) is the fallback.
# Adding GROQ_API_KEY makes generation 10x faster.
# =====================================================
